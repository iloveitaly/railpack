#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# dependencies = [
#   "click"
# ]
# ///

import sys
import subprocess
import os
import click
import shutil
import tempfile
import time
import re
from pathlib import Path

MASTER_BRANCH_REF = "main"

def run_command(command, check=True, capture_output=False, text=True, cwd=None):
    """Helper to run a shell command, exiting on failure."""
    click.secho(f"+ {command}", dim=True, err=True)
    try:
        return subprocess.run(command, shell=True, check=check, capture_output=capture_output, text=text, cwd=cwd)
    except subprocess.CalledProcessError as e:
        click.secho(f"Error running command: {e.cmd}", fg="red", err=True)
        if e.stdout:
            click.secho(f"STDOUT: {e.stdout}", fg="red", err=True)
        if e.stderr:
            click.secho(f"STDERR: {e.stderr}", fg="red", err=True)
        sys.exit(1)

def get_ai_tool():
    """Determines the available AI tool and returns its executable name."""
    if shutil.which("grok"):
        return "grok"
    elif shutil.which("agy"):
        return "agy"
    elif shutil.which("claude") and False:
        return "claude"
    elif shutil.which("cursor-agent"):
        return "cursor-agent"
    else:
        click.secho("Error: Could not find 'grok', 'agy', 'claude', or 'cursor-agent' executable in PATH.", fg="red", err=True)
        sys.exit(1)

def run_ai_prompt(ai_tool, prompt_path, cwd=None):
    """Runs an AI tool with the given prompt file."""
    prompt = Path(prompt_path).read_text()
    click.secho(f"+ {ai_tool} -p <prompt>", dim=True, err=True)
    try:
        return subprocess.run(
            [ai_tool, "-p", prompt],
            check=True,
            capture_output=True,
            text=True,
            cwd=cwd,
        )
    except subprocess.CalledProcessError as e:
        click.secho(f"Error running command: {ai_tool} -p <prompt>", fg="red", err=True)
        if e.stdout:
            click.secho(f"STDOUT: {e.stdout}", fg="red", err=True)
        if e.stderr:
            click.secho(f"STDERR: {e.stderr}", fg="red", err=True)
        sys.exit(1)

def fetch_git_history(repo_root):
    """Fetches git history using git-history-extraction."""
    history_cmd = "uvx git-history-extraction@latest --since-last-tag --remote --format json"
    history_result = run_command(history_cmd, capture_output=True, cwd=repo_root)
    return compress_history(history_result.stdout)

def compress_history(history):
    """Compresses large lists of snapshot files in the git history."""
    def replacement(match):
        prefix = match.group(1)
        # count = match.group(2)
        files_str = match.group(3)
        
        files = [f.strip() for f in files_str.split(',')]
        snapshots = [f for f in files if '/__snapshots__/' in f]
        others = [f for f in files if '/__snapshots__/' not in f]
        
        if not snapshots:
            return match.group(0)
            
        new_files = others + [f"[updated {len(snapshots)} snapshots]"]
        return f"{prefix}[{len(new_files)}]: {', '.join(new_files)}"

    return re.sub(r'^(\s+files)\[(\d+)\]: (.*)$', replacement, history, flags=re.MULTILINE)

@click.command()
@click.argument('increment_type', type=click.Choice(['patch', 'minor', 'major']), required=False)
@click.option('--auto', is_flag=True, help='Automatically determine the version bump from git history.')
@click.option('--no-release-notes', is_flag=True, help='Skip automated release note generation.')
def main(increment_type, auto, no_release_notes):
    """Creates and pushes a new release tag."""
    # TODO: Refactor to use GitPython for improved Git interaction.
    try:
        # Get repo root
        repo_root_result = run_command("git rev-parse --show-toplevel", capture_output=True)
        repo_root = repo_root_result.stdout.strip()

        # Determine the remote to use
        remote_name = "origin"
        try:
            run_command("git remote get-url upstream", capture_output=True, check=True, cwd=repo_root)
            remote_name = "upstream"
            click.secho("Using 'upstream' remote for operations.", fg="blue")
        except subprocess.CalledProcessError:
            click.secho("No 'upstream' remote found, using 'origin'.", fg="yellow")

        # Fetch latest changes from remote and fetch tags
        click.secho(f"Fetching latest changes from {remote_name}/{MASTER_BRANCH_REF} and tags...", fg="blue")
        run_command(f"git fetch {remote_name} {MASTER_BRANCH_REF}", cwd=repo_root)
        run_command(f"git fetch --tags {remote_name}", cwd=repo_root)

        # Get latest tag (reachable from remote main)
        latest_tag_result = run_command(f"git describe --tags --abbrev=0 {remote_name}/{MASTER_BRANCH_REF}", capture_output=True, check=False, cwd=repo_root)
        if latest_tag_result.returncode != 0 or not latest_tag_result.stdout.strip():
            latest_tag = "v0.0.0"
            latest_tag_ref = ""
        else:
            latest_tag = latest_tag_result.stdout.strip()
            latest_tag_ref = latest_tag

        raw_history = None

        if auto:
            if increment_type:
                click.secho("Error: Cannot use --auto and specify an increment type at the same time.", fg="red", err=True)
                sys.exit(1)
            
            click.secho("Automatically determining version bump from git history...", fg="blue")
            
            # Fetch history for analysis
            raw_history = fetch_git_history(repo_root)
            
            ai_tool = get_ai_tool()
            click.secho(f"Using '{ai_tool}' for analysis...", fg="cyan")

            # Construct prompt for bump detection
            bump_prompt = f"{raw_history}\n\nAnalyze the git log above. What is the recommended semantic version bump? Respond with only one word: 'major', 'minor', or 'patch'."

            # Use tempfile.NamedTemporaryFile (delete=False) in the local ./tmp/ directory.
            # This is better than shelling out to mktemp, gives a unique safe name (vs hardcoding),
            # follows the project rule to use local tmp/ instead of global /tmp, and leaves the file
            # so the gray reference can be used to debug the exact prompt sent to the AI.
            tmp_dir = Path(repo_root) / "tmp"
            tmp_dir.mkdir(parents=True, exist_ok=True)
            with tempfile.NamedTemporaryFile(
                mode="w", delete=False, dir=tmp_dir, prefix="railpack-bump-prompt-", suffix=".txt"
            ) as f:
                f.write(bump_prompt)
                bump_prompt_path = f.name

            click.secho(f"+ prompt: {Path(bump_prompt_path).relative_to(repo_root)}", dim=True, err=True)

            result = run_ai_prompt(ai_tool, bump_prompt_path, cwd=repo_root)
            recommended_bump = result.stdout.strip().lower()

            # Cleanup response (sometimes AI adds extra text/punctuation)
            match = re.search(r'\b(major|minor|patch)\b', recommended_bump)
            if match:
                recommended_bump = match.group(1)
            else:
                click.secho(f"Error: Auto-detection returned an invalid choice: '{recommended_bump}'", fg="red", err=True)
                sys.exit(1)
            
            click.secho(f"Recommended bump: '{recommended_bump}'", fg="green")
            if not click.confirm("Do you want to proceed with this recommendation?"):
                click.secho("Aborted by user.", fg="yellow")
                sys.exit(0)
            increment_type = recommended_bump
        
        # If --auto is not used, and increment_type is not provided, error out
        if not auto and increment_type is None:
            click.secho("Error: An increment type (patch, minor, or major) must be provided if --auto is not used.", fg="red", err=True)
            sys.exit(1)

        # Increment version
        latest_version = latest_tag.lstrip('v')
        try:
            major, minor, patch = map(int, latest_version.split('.'))
        except ValueError:
            click.secho(f"Error: Could not parse version from tag '{latest_tag}'. Expected format 'vX.Y.Z'.", fg="red", err=True)
            sys.exit(1)

        if increment_type == "major":
            major += 1
            minor = 0
            patch = 0
        elif increment_type == "minor":
            minor += 1
            patch = 0
        elif increment_type == "patch":
            patch += 1

        new_version = f"v{major}.{minor}.{patch}"

        click.secho(f"Latest tag: {latest_tag}", fg="yellow")
        click.secho(f"New version ({increment_type}): {new_version}\n", fg="green", bold=True) # Added \n for spacing

        # --- Release Notes Generation ---
        summary_file_path = None
        if not no_release_notes:
            click.secho("Generating release notes...", fg="blue")

            # 1. Ensure we have history
            if raw_history is None:
                raw_history = fetch_git_history(repo_root)

            # 2. Read prompt template
            prompt_path = Path(repo_root) / ".mise/tasks/release-prompt.txt"
            prompt_template = prompt_path.read_text()

            # 3. Combine
            full_prompt = f"Previous Version: {latest_tag}\nNew Version: {new_version}\n\n{prompt_template}\n\n{raw_history}"

            # 4. Run AI (Grok/Antigravity/Claude/Cursor)
            ai_tool = get_ai_tool()
            click.secho(f"Asking {ai_tool} to summarize...", fg="cyan")

            # Use tempfile.NamedTemporaryFile (delete=False) in the local ./tmp/ directory.
            # This is better than shelling out to mktemp, gives a unique safe name (vs hardcoding),
            # follows the project rule to use local tmp/ instead of global /tmp, and leaves the file
            # so the gray reference can be used to debug the exact prompt sent to the AI.
            tmp_dir = Path(repo_root) / "tmp"
            tmp_dir.mkdir(parents=True, exist_ok=True)
            with tempfile.NamedTemporaryFile(
                mode="w", delete=False, dir=tmp_dir, prefix="railpack-release-prompt-", suffix=".txt"
            ) as f:
                f.write(full_prompt)
                prompt_file_path = f.name

            click.secho(f"+ prompt: {Path(prompt_file_path).relative_to(repo_root)}", dim=True, err=True)

            summary_result = run_ai_prompt(ai_tool, prompt_file_path)
            summary = summary_result.stdout.strip()

            # Remove markdown code block wrapping if present
            summary = re.sub(r'^```[a-zA-Z]*\n', '', summary)
            summary = re.sub(r'\n```$', '', summary)
            summary = summary.strip()

            # 5. Write summary to temp file for user editing
            with tempfile.NamedTemporaryFile(mode='w', delete=False, suffix=".md", prefix="railpack-release-notes-") as summary_file:
                summary_file.write(summary)
                summary_file_path = summary_file.name

            click.secho(f"\nRelease notes generated at: {summary_file_path}", fg="green")
            click.secho("-" * 40, dim=True)
            click.echo(summary)
            click.secho("-" * 40, dim=True)

            # 6. Prompt for edit
            if click.confirm(f"Do you want to edit these release notes?", default=False):
                click.edit(filename=summary_file_path)
                
                # Re-read file
                summary = Path(summary_file_path).read_text()
                click.secho("Reloaded release notes.", fg="green")

        # Confirmation
        msg = f"This will create and push the tag {new_version}"
        if not no_release_notes:
            msg += " and update the release notes"
        msg += ". Are you sure?"
        
        if not click.confirm(msg):
            click.secho("Aborted by user.", fg="yellow")
            sys.exit(0)

        # Create and push tag
        click.secho(f"Creating and pushing tag {new_version}...", fg="blue")
        # Tag the remote main commit
        run_command(f"git tag {new_version} {remote_name}/{MASTER_BRANCH_REF}", cwd=repo_root)
        run_command(f"git push {remote_name} {new_version}", cwd=repo_root)

        click.secho(f"Successfully created and pushed tag {new_version}.", fg="green", bold=True)

        if not no_release_notes:
            # Update GitHub Release
            click.secho(f"Waiting for GitHub Release {new_version} to be created (timeout: 30m)...", fg="blue")
            start_time = time.time()
            found = False
            while time.time() - start_time < 30 * 60: # 30 minutes
                # Check if release exists
                check_cmd = f"gh release view {new_version} --json url"
                proc = run_command(check_cmd, check=False, capture_output=True)
                if proc.returncode == 0:
                    found = True
                    break
                
                click.echo(".", nl=False)
                sys.stdout.flush()
                time.sleep(60) # Check every minute
            
            click.echo("") # Newline
            
            if found:
                click.secho("Release found! Updating release notes...", fg="green")
                # Update notes using the temp file
                run_command(f"gh release edit {new_version} --notes-file '{summary_file_path}'")
                click.secho(f"Release notes for {new_version} updated successfully.", fg="green", bold=True)
                
                # Clean up summary file only on success
                if os.path.exists(summary_file_path):
                    os.unlink(summary_file_path)
            else:
                click.secho(f"Timeout: Release {new_version} was not found on GitHub after 30 minutes. Release notes were not updated.", fg="red")
                click.secho(f"You can manually update the release notes using the file: {summary_file_path}", fg="yellow")
                # Don't delete the file if failed
                return

    except Exception as e:
        click.secho(f"An unexpected error occurred: {e}", fg="red", err=True)
        sys.exit(1)

if __name__ == "__main__":
    main()
